{
	color: White;
	text-decoration: none;
}      
a.MenuItem:hover
{
	text-decoration: underline;
}
.SelectedMenuItem
{
	color:Blue;
	font-size: 18px;
	line-height: 2em;
}
a.SelectedMenuItem:link, a.SelectedMenuItem:visited, a.SelectedMenuItem:active
{
	text-decoration: none;
}      
a.SelectedMenuItem:hover
{
	text-decoration: underline;
}
.Legal
{
	font-size: 9px;
}
