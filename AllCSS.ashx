{
	text-decoration: none;
	color: white; 
}      
a.BannerText:hover
{
	text-decoration: underline;
	color: white; 
}
.OKCancelButton
{
	width: 80px;
}
.SmallerFont
{
	font-size: 10px;
}
.RP
{
	font-size: 10px;
	color: #cc3366;
}
.MenuItem
{
	color: White;
	font-size: 18px;
	line-height: 2em;
}
