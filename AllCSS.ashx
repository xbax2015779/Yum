.Panel h4
{
	background-color: #ccc;
	border-bottom: solid 1px #000;
	color: #333;
	margin: 0;
	text-align: center;
}

.MultilineTextBox
{
	border: dashed 2px Gray;
	font-family: Verdana, Sans-Serif;
	font-size: 1.2em;
	/*height: auto !important;*/
	height: 250px;
	line-height: 1.5em;
	min-height: 250px;
