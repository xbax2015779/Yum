{
	text-decoration: none;
}      
a.Title:hover
{
	text-decoration: underline;
}
.Header
{
	font-size: 14px;
}
.Banner
{
	padding: 8px;
}
.BannerText
{
	font-weight: bold;
	color: white;
}
