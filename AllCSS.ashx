{
	color: Green;
}

#Banner #Alerts #RobuxAlert a:hover
{
	color: #49b745;
}

#Banner #Alerts #TicketsAlert a
{
	color: #fbb117;
}

#Banner #Alerts #TicketsAlert a:hover
{
	color: #fdd017;
}

